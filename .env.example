# This is an example .env for the RT-BackEnd project.
# Copy this file to .env and fill in the required values.

# Server
PORT=3000
NODE_ENV=development

# Database connection strings (use Supabase connection URIs per env)
# For Supabase, DIRECT_URL is optional; if using connection pooling, use pooled URL for DATABASE_URL
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public"

# SMTP / Mail settings
SMTP_PASS="<password key>"
SMTP_SERVER="smtp-relay.brevo.com"
SMTP_PORT=587
SMTP_USER="<id>@smtp-brevo.com"
#NOTE: for the migrations in production instance, the supabase URL's must be used