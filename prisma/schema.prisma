generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  admin
  coordinator
  tutor
  parent
}

enum AccountType {
  ahorro
  corriente
  vista
}

enum ClassModality {
  inPerson
  online
  cancelled
}

enum ClassType {
  schoolar
  universitary
}

enum PaymentStatus {
  completed
  pending
}

enum PaymentType {
  card
  bankTransfer
}

model Class {
  id            Int        @id @default(autoincrement())
  date          DateTime
  subject       String
  modality      ClassModality
  studentNumber Int
  type          ClassType
  duration      Int

  studentId     Int
  Student       Student     @relation(fields: [studentId], references: [id])

  tutorId       Int
  Tutor         User        @relation("TutorClasses", fields: [tutorId], references: [id])

  institutionId Int
  Institution   Institution @relation(fields: [institutionId], references: [id])

  ClassPayments ClassPayment[]

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([institutionId])
  @@index([tutorId])
  @@index([studentId])
}

model ClassPayment {
  id                Int           @id @default(autoincrement())
  classId           Int
  feeId             Int
  paymentFromParent PaymentStatus @default(pending)
  paymentToTutor    PaymentStatus @default(pending)
  paymentType       PaymentType   @default(bankTransfer)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  Class             Class         @relation(fields: [classId], references: [id])
  Fee               Fee           @relation(fields: [feeId], references: [id])
}

model CoordinatorPayment {
  id            Int      @id @default(autoincrement())
  institutionId Int
  periodYear    Int
  periodMonth   Int
  amount        Int
  Institution   Institution @relation(fields: [institutionId], references: [id])

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([institutionId, periodYear, periodMonth])
}

model AdminPayment {
  id            Int      @id @default(autoincrement())
  periodYear    Int
  periodMonth   Int
  amount        Int

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Fee {
  id                Int      @id @default(autoincrement())
  type              String
  classModality     ClassModality
  studentNumber     Int
  amountToPay       Int
  amountToCharge    Int
  institutionId     Int
  currentlyActive   Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  ClassPayments     ClassPayment[]
  Institution       Institution @relation(fields: [institutionId], references: [id])
}

model Institution {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  Users     User[]
  Fees      Fee[]
  Classes   Class[]
  CoordinatorPayments CoordinatorPayment[]
  ParentTutors ParentTutor[]
  Students  Student[]
}

model ParentTutor {
  parentId      Int
  tutorId       Int
  institutionId Int
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  Parent        User        @relation("ParentTutorParent", fields: [parentId], references: [id])
  Tutor         User        @relation("ParentTutorTutor",  fields: [tutorId],  references: [id])
  Institution   Institution @relation(fields: [institutionId], references: [id])

  @@id([parentId, tutorId, institutionId])
  @@index([tutorId])
  @@index([institutionId])
}

model Student {
  id            Int        @id @default(autoincrement())
  name          String
  parentId      Int
  institutionId Int

  Parent        User        @relation("ParentStudents", fields: [parentId], references: [id])
  Institution   Institution @relation(fields: [institutionId], references: [id])

  Classes       Class[]
  @@index([parentId])
  @@index([institutionId])
}

model User {
  id                Int      @id @default(autoincrement())
  hashedPassword    String
  name              String
  role              UserRole
  email             String   @unique
  rut               String?  @unique
  phone             String?  
  address           String?
  chargeEmail       String?
  institutionId     Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  BankAccount       UserBankAccount?
  Institution       Institution?  @relation(fields: [institutionId], references: [id])

  ParentLinks       ParentTutor[]  @relation("ParentTutorParent")
  TutorLinks        ParentTutor[]  @relation("ParentTutorTutor")
  Students          Student[]      @relation("ParentStudents")
  ClassesAsTutor    Class[]        @relation("TutorClasses")
  RefreshTokens     RefreshToken[] @relation("RefreshTokens")
  @@index([role])
}

model UserBankAccount {
  id             Int      @id @default(autoincrement())
  userId         Int      @unique
  bankName       String
  accountType    AccountType
  accountNumber  String
  accountEmail   String
  rutHolder      String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  User           User     @relation(fields: [userId], references: [id])

  @@unique([userId, accountNumber])
}


model RefreshToken {
  id           String   @id @default(cuid())
  userId       Int
  tokenHash    String
  revoked      Boolean  @default(false)
  createdAt    DateTime @default(now())
  expiresAt    DateTime

  User         User     @relation("RefreshTokens", fields: [userId], references: [id])
  @@index([userId])
  @@index([expiresAt])
}
