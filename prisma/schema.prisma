generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  admin
  coordinator
  guardian
  tutor
}

enum AccountType {
  Ahorro
  Corriente
  Vista
}

enum ClassSubject {
  biology
  chemistry
  physics
  mathematics
  spanish
  french
  english
  pet
  socialStudies
  studySkills
  other
}

enum ClassModality {
  inPerson
  online
}

enum ClassType {
  school
  university
  cancelled
}

enum PaymentStatus {
  completed
  pending
}

enum PaymentType {
  card
  bankTransfer
}

model AdminPayment {
  id            Int      @id @default(autoincrement())
  periodYear    Int
  periodMonth   Int
  amount        Int
  status        PaymentStatus @default(pending)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([periodYear, periodMonth])
  @@index([periodYear, periodMonth])
}

model CoordinatorPayment {
  id            Int      @id @default(autoincrement())
  coordinatorId Int
  institutionId Int
  periodYear    Int
  periodMonth   Int
  amount        Int
  status        PaymentStatus @default(pending)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  Coordinator   User     @relation(fields: [coordinatorId], references: [id])
  Institution   Institution @relation(fields: [institutionId], references: [id])

  @@unique([institutionId, periodYear, periodMonth])
  @@index([periodYear, periodMonth])
}

model CoordinatorProfitShare {
  id            Int      @id @default(autoincrement())
  coordinatorId Int
  institutionId Int
  profitShare   Decimal  @db.Decimal(5, 3)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  Coordinator   User     @relation(fields: [coordinatorId], references: [id])
  Institution   Institution @relation(fields: [institutionId], references: [id])
  
  @@unique([coordinatorId, institutionId])
  @@index([institutionId])
  @@index([coordinatorId])
}

model Class {
  id            Int        @id @default(autoincrement())
  date          DateTime
  subject       ClassSubject
  modality      ClassModality
  numberOfStudents Int
  type          ClassType
  duration      Int
  institutionId Int
  studentId     Int
  tutorId       Int
  ClassPayment  ClassPayment?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  Institution   Institution @relation(fields: [institutionId], references: [id])
  Student       Student     @relation(fields: [studentId], references: [id])
  Tutor         User        @relation("TutorClasses", fields: [tutorId], references: [id])
  
  @@index([institutionId])
  @@index([tutorId])
  @@index([studentId])
}

model ClassPayment {
  id                      Int           @id @default(autoincrement())
  classId                 Int
  guardianAmount          Int           
  guardianPaymentStatus   PaymentStatus @default(pending)
  guardianPaymentType             PaymentType   @default(bankTransfer)
  tutorAmount             Int
  tutorPaymentStatus      PaymentStatus @default(pending)
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  Class                   Class         @relation(fields: [classId], references: [id])
  
  @@unique([classId])
  @@index([createdAt])
}


model Fee {
  id                Int      @id @default(autoincrement())
  type              ClassType
  modality          ClassModality
  numberOfStudents  Int      @default(1)
  tutorAmount       Int      @default(0)
  guardianAmount    Int      @default(0)
  institutionId     Int
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  Institution       Institution @relation(fields: [institutionId], references: [id])
 
  @@index([institutionId])
  @@unique([type, modality, numberOfStudents, institutionId])
}

model Institution {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  Users               User[]
  Fees                Fee[]
  Classes             Class[]
  CoordinatorPayments CoordinatorPayment[]
  GuardianTutors      GuardianTutor[]
  Students            Student[]

  coordinatorProfitShares CoordinatorProfitShare[]
}

model GuardianTutor {
  guardianId    Int
  tutorId       Int
  institutionId Int
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  Guardian      User        @relation("GuardianTutorGuardian", fields: [guardianId], references: [id])
  Tutor         User        @relation("GuardianTutorTutor",  fields: [tutorId],  references: [id])
  Institution   Institution @relation(fields: [institutionId], references: [id])

  @@id([guardianId, tutorId, institutionId])
  @@index([tutorId])
  @@index([institutionId])
  @@index([guardianId])
}

model Student {
  id            Int        @id @default(autoincrement())
  name          String
  guardianId    Int
  institutionId Int

  Guardian      User        @relation("GuardianStudents", fields: [guardianId], references: [id])
  Institution   Institution @relation(fields: [institutionId], references: [id])
  Classes       Class[]
  
  @@index([guardianId])
  @@index([institutionId])
}

model User {
  id                Int      @id @default(autoincrement())
  hashedPassword    String
  name              String
  role              UserRole
  email             String   @unique
  rut               String  
  phone             String?  
  address           String?
  chargeEmail       String?
  institutionId     Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  isActive          Boolean  @default(true)

  BankAccount       UserBankAccount?
  Institution       Institution?  @relation(fields: [institutionId], references: [id])

  GuardianLinks       GuardianTutor[]  @relation("GuardianTutorGuardian")
  TutorLinks        GuardianTutor[]  @relation("GuardianTutorTutor")
  Students          Student[]      @relation("GuardianStudents")
  ClassesAsTutor    Class[]        @relation("TutorClasses")
  RefreshTokens     RefreshToken[] @relation("RefreshTokens")
  @@index([role])
  @@index([institutionId])
  @@index([institutionId, role])
  coordinatorPayments CoordinatorPayment[]
  coordinatorProfitShares CoordinatorProfitShare[]
}

model UserBankAccount {
  id             Int      @id @default(autoincrement())
  userId         Int      @unique
  bankName       String
  accountType    AccountType
  accountName    String   @default("")
  accountNumber  String
  accountEmail   String
  rut            String   @default("")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  User           User     @relation(fields: [userId], references: [id])
}


model RefreshToken {
  id           String   @id @default(cuid())
  userId       Int
  tokenHash    String
  revoked      Boolean  @default(false)
  createdAt    DateTime @default(now())
  expiresAt    DateTime

  User         User     @relation("RefreshTokens", fields: [userId], references: [id])
  @@index([userId])
  @@index([expiresAt])
}