generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  admin
  coordinator
  tutor
  guardian
}

enum AccountType {
  ahorro
  corriente
  vista
}

enum ClassModality {
  inPerson
  online
  cancelled
}

enum ClassType {
  schoolar
  universitary
}

enum PaymentStatus {
  completed
  pending
}

enum PaymentType {
  card
  bankTransfer
}

model AdminPayment {
  id            Int      @id @default(autoincrement())
  periodYear    Int
  periodMonth   Int
  amount        Int

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@unique([periodYear, periodMonth])
  @@index([periodYear, periodMonth])
}


model Class {
  id            Int        @id @default(autoincrement())
  date          DateTime
  subject       String
  modality      ClassModality
  studentNumber Int
  type          ClassType
  duration      Int

  studentId     Int
  Student       Student     @relation(fields: [studentId], references: [id])

  tutorId       Int
  Tutor         User        @relation("TutorClasses", fields: [tutorId], references: [id])

  institutionId Int
  Institution   Institution @relation(fields: [institutionId], references: [id])

  ClassPayments ClassPayment[]

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([institutionId])
  @@index([tutorId])
  @@index([studentId])
}

model ClassPayment {
  id                      Int           @id @default(autoincrement())
  classId                 Int
  guardianPaymentStatus   PaymentStatus @default(pending)
  tutorPaymentStatus      PaymentStatus @default(pending)
  totalGuardianAmount     Int
  totalTutorAmount        Int
  paymentType             PaymentType   @default(bankTransfer)
  
  Class                   Class         @relation(fields: [classId], references: [id])
  
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt
  
  @@unique([classId])
  @@index([createdAt])
}

model CoordinatorPayment {
  id            Int      @id @default(autoincrement())
  institutionId Int
  periodYear    Int
  periodMonth   Int
  amount        Int
  Institution   Institution @relation(fields: [institutionId], references: [id])

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([institutionId, periodYear, periodMonth])
  @@index([periodYear, periodMonth])
}

model CoordinatorProfitShare {
  id            Int      @id @default(autoincrement())
  coordinatorId Int
  institutionId Int
  profitShare   Decimal  @db.Decimal(5, 3)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  Coordinator   User     @relation(fields: [coordinatorId], references: [id])
  Institution   Institution @relation(fields: [institutionId], references: [id])
  @@unique([coordinatorId, institutionId])
  @@index([institutionId])
  @@index([coordinatorId])
}

model Fee {
  id                Int      @id @default(autoincrement())
  type              String
  classModality     ClassModality
  numberOfStudents  Int
  tutorAmount       Int
  guardianAmount    Int
  institutionId     Int
  currentlyActive   Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  Institution       Institution @relation(fields: [institutionId], references: [id])
  @@index([institutionId])
  @@unique([type, classModality, numberOfStudents, institutionId])
}

model Institution {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  Users               User[]
  Fees                Fee[]
  Classes             Class[]
  CoordinatorPayments CoordinatorPayment[]
  GuardianTutors      GuardianTutor[]
  Students            Student[]
}

model GuardianTutor {
  guardianId    Int
  tutorId       Int
  institutionId Int
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  Guardian      User        @relation("GuardianTutorGuardian", fields: [guardianId], references: [id])
  Tutor         User        @relation("GuardianTutorTutor",  fields: [tutorId],  references: [id])
  Institution   Institution @relation(fields: [institutionId], references: [id])

  @@id([guardianId, tutorId, institutionId])
  @@index([tutorId])
  @@index([institutionId])
  @@index([guardianId])
}

model Student {
  id            Int        @id @default(autoincrement())
  name          String
  guardianId    Int
  institutionId Int

  Guardian      User        @relation("GuardianStudents", fields: [guardianId], references: [id])
  Institution   Institution @relation(fields: [institutionId], references: [id])
  Classes       Class[]
  @@index([guardianId])
  @@index([institutionId])
}

model User {
  id                Int      @id @default(autoincrement())
  hashedPassword    String
  name              String
  role              UserRole
  email             String   @unique
  rut               String?  @unique
  phone             String?  
  address           String?
  chargeEmail       String?
  institutionId     Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  BankAccount       UserBankAccount?
  Institution       Institution?  @relation(fields: [institutionId], references: [id])

  GuardianLinks       GuardianTutor[]  @relation("GuardianTutorGuardian")
  TutorLinks        GuardianTutor[]  @relation("GuardianTutorTutor")
  Students          Student[]      @relation("GuardianStudents")
  ClassesAsTutor    Class[]        @relation("TutorClasses")
  RefreshTokens     RefreshToken[] @relation("RefreshTokens")
  @@index([role])
  @@index([institutionId])
  @@index([institutionId, role])
}

model UserBankAccount {
  id             Int      @id @default(autoincrement())
  userId         Int      @unique
  bankName       String
  accountType    AccountType
  accountNumber  String
  accountEmail   String
  rutHolder      String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  User           User     @relation(fields: [userId], references: [id])
}


model RefreshToken {
  id           String   @id @default(cuid())
  userId       Int
  tokenHash    String
  revoked      Boolean  @default(false)
  createdAt    DateTime @default(now())
  expiresAt    DateTime

  User         User     @relation("RefreshTokens", fields: [userId], references: [id])
  @@index([userId])
  @@index([expiresAt])
}
